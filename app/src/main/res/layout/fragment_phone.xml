<?xml version="1.0" encoding="utf-8"?>
<!-- CarPlay Phone Layout — Modernized -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:paddingHorizontal="20dp">

    <!-- Tab Bar (pill style) -->
    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/btn_source_bg"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tabKeypad"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/btn_carplay_bg"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="Keypad"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tabRecents"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="Recents"
            android:textColor="@color/text_tertiary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tabContacts"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="Contacts"
            android:textColor="@color/text_tertiary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Phone Number Display -->
    <TextView
        android:id="@+id/txtPhoneNumber"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:hint="Enter number"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/carplay_gray"
        android:textSize="36sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="-0.02"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabBar" />

    <!-- Dialpad -->
    <GridLayout
        android:id="@+id/dialpadLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:columnCount="3"
        android:rowCount="4"
        app:layout_constraintBottom_toTopOf="@id/callButtonLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtPhoneNumber">

        <!-- Row 1: 1, 2, 3 -->
        <TextView
            android:id="@+id/btn1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="4dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/app_tile_ripple"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:id="@+id/btn2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="4dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/app_tile_ripple"
            android:gravity="center"
            android:text="2"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:id="@+id/btn3"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="4dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/app_tile_ripple"
            android:gravity="center"
            android:text="3"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light" />

        <!-- Row 2: 4, 5, 6 -->
        <TextView
            android:id="@+id/btn4"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="4dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/app_tile_ripple"
            android:gravity="center"
            android:text="4"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:id="@+id/btn5"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="4dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/app_tile_ripple"
            android:gravity="center"
            android:text="5"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:id="@+id/btn6"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="4dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/app_tile_ripple"
            android:gravity="center"
            android:text="6"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light" />

        <!-- Row 3: 7, 8, 9 -->
        <TextView
            android:id="@+id/btn7"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="4dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/app_tile_ripple"
            android:gravity="center"
            android:text="7"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:id="@+id/btn8"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="4dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/app_tile_ripple"
            android:gravity="center"
            android:text="8"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:id="@+id/btn9"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="4dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/app_tile_ripple"
            android:gravity="center"
            android:text="9"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light" />

        <!-- Row 4: *, 0, # -->
        <TextView
            android:id="@+id/btnStar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="4dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/app_tile_ripple"
            android:gravity="center"
            android:text="*"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:id="@+id/btn0"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="4dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/app_tile_ripple"
            android:gravity="center"
            android:text="0"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:id="@+id/btnHash"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="4dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/app_tile_ripple"
            android:gravity="center"
            android:text="#"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light" />
    </GridLayout>

    <!-- Call & Backspace -->
    <LinearLayout
        android:id="@+id/callButtonLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnBackspace"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/app_tile_ripple"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/carplay_gray_light" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnCall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="40dp"
            android:src="@android:drawable/ic_menu_call"
            app:backgroundTint="@color/carplay_green"
            app:tint="@color/text_primary"
            app:fabSize="normal" />

        <!-- Contacts shortcut -->
        <ImageButton
            android:id="@+id/btnContacts"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/app_tile_ripple"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:tint="@color/carplay_gray_light" />
    </LinearLayout>

    <!-- Recents List (hidden by default) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recentsLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabBar" />

    <!-- Contacts List (hidden by default) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/contactsLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabBar" />

</androidx.constraintlayout.widget.ConstraintLayout>
