<?xml version="1.0" encoding="utf-8"?>
<!-- Modern CarPlay Dashboard — App Launcher -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:paddingHorizontal="20dp"
    android:paddingTop="8dp">

    <!-- Clock -->
    <TextView
        android:id="@+id/txtTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12:00"
        android:textColor="@color/text_primary"
        android:textSize="56sp"
        android:fontFamily="sans-serif-thin"
        android:letterSpacing="-0.02"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Date -->
    <TextView
        android:id="@+id/txtDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:text="Monday, January 1"
        android:textColor="@color/text_tertiary"
        android:textSize="15sp"
        android:fontFamily="sans-serif"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTime" />

    <!-- Now Playing Widget (compact) -->
    <LinearLayout
        android:id="@+id/nowPlayingCard"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/now_playing_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtDate">

        <!-- Album Art Placeholder -->
        <View
            android:id="@+id/imgAlbumArt"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@color/surface_elevated" />

        <!-- Song Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtSongTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No track playing"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/txtArtist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Connect to start"
                android:textColor="@color/text_tertiary"
                android:textSize="13sp"
                android:ellipsize="end"
                android:maxLines="1" />

            <!-- Progress bar (thin) -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="6dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/carplay_blue"
                android:progressBackgroundTint="@color/surface_elevated" />
        </LinearLayout>

        <!-- Playback controls (inline) -->
        <ImageButton
            android:id="@+id/btnPrev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_play"
            android:tint="@color/carplay_blue" />

        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_next"
            android:tint="@color/text_secondary" />
    </LinearLayout>

    <!-- Section Title: Apps -->
    <TextView
        android:id="@+id/txtAppsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="APPS"
        android:textColor="@color/text_tertiary"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.08"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nowPlayingCard" />

    <!-- App Grid -->
    <GridLayout
        android:id="@+id/appGrid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:columnCount="4"
        android:rowCount="2"
        android:useDefaultMargins="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtAppsTitle">

        <!-- Google Maps -->
        <androidx.cardview.widget.CardView
            android:id="@+id/tileMaps"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="6dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            app:cardBackgroundColor="@color/google_maps_blue"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_google_maps"
                    android:scaleType="fitCenter" />

                <TextView
                    style="@style/AppTileLabel"
                    android:text="Maps" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- YouTube -->
        <androidx.cardview.widget.CardView
            android:id="@+id/tileYouTube"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="6dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            app:cardBackgroundColor="@color/youtube_red"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_youtube"
                    android:scaleType="fitCenter" />

                <TextView
                    style="@style/AppTileLabel"
                    android:text="YouTube" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- YouTube Music -->
        <androidx.cardview.widget.CardView
            android:id="@+id/tileYouTubeMusic"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="6dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            app:cardBackgroundColor="@color/youtube_music_orange"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_youtube_music"
                    android:scaleType="fitCenter" />

                <TextView
                    style="@style/AppTileLabel"
                    android:text="YT Music" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Phone -->
        <androidx.cardview.widget.CardView
            android:id="@+id/tilePhone"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="6dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            app:cardBackgroundColor="@color/carplay_green"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_phone_carplay"
                    android:scaleType="fitCenter" />

                <TextView
                    style="@style/AppTileLabel"
                    android:text="Phone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Row 2: Settings, Spotify placeholder, Telegram placeholder, placeholder -->
        <androidx.cardview.widget.CardView
            android:id="@+id/tileSettings"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="6dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            app:cardBackgroundColor="@color/carplay_gray"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_settings_carplay"
                    android:scaleType="fitCenter" />

                <TextView
                    style="@style/AppTileLabel"
                    android:text="Settings" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Spotify placeholder -->
        <androidx.cardview.widget.CardView
            android:id="@+id/tileSpotify"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="6dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            app:cardBackgroundColor="#1DB954"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="♫"
                    android:textSize="32sp"
                    android:textColor="#FFFFFF" />

                <TextView
                    style="@style/AppTileLabel"
                    android:text="Spotify" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Telegram -->
        <androidx.cardview.widget.CardView
            android:id="@+id/tileTelegram"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="6dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            app:cardBackgroundColor="#0088CC"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✈"
                    android:textSize="28sp"
                    android:textColor="#FFFFFF" />

                <TextView
                    style="@style/AppTileLabel"
                    android:text="Telegram" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Empty slot -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="6dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            app:cardBackgroundColor="#2C2C2E"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp" />
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
